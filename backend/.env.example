# Database Individual Credentials
DB_HOST="localhost"
DB_PORT=5432
DB_USER="postgres"
DB_PASSWORD="your_db_password"
DB_NAME="ims_db"

# Prisma Connection String (Required by Prisma)
DATABASE_URL="postgresql://postgres:your_db_password@localhost:5432/ims_db?schema=public"

# Redis Configuration (For JWT Denylist)
REDIS_URL="redis://localhost:6379"

# JWT Security
# NOTE: Keys dynamically generated via generate-keys.js
JWT_PRIVATE_KEY_PATH="/var/ims/keys/private.pem"
JWT_PUBLIC_KEY_PATH="/var/ims/keys/public.pem"
JWT_EXPIRY_MINUTES=60
JWT_LOCKOUT_ATTEMPTS=5
JWT_LOCKOUT_DURATION_MINUTES=30
SESSION_INACTIVITY_TIMEOUT_MINUTES=60
RESET_LINK_EXPIRY_MINUTES=60
BCRYPT_COST_FACTOR=12

# File Storage & Security
FILE_STORAGE_ROOT="/mnt/ims/files"
CLAMAV_SOCKET_PATH="/var/run/clamav/clamd.ctl"
MAX_FILE_SIZE_MB=10

# Email (Nodemailer / Postfix Relay)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=AtinafBedasaa@gmail.com
SMTP_PASS="your_smtp_password"

# Application Business Logic Thresholds
MAX_STUDENTS_PER_APPLICATION=50
SUPERVISOR_DEFAULT_MAX_STUDENTS=10

# System Settings
APP_TIMEZONE="Africa/Addis_Ababa"
PORT=3000
FRONTEND_URL="https://ims.mint.gov.et"

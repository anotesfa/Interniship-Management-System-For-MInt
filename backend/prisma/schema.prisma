// prisma/schema.prisma  — IMS v2.0  (aligned with IMS-DDD-001 v1.0)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── IDENTITY & ACCESS ────────────────────────────────────────────────────
model Role {
  role_id   Int    @id @default(autoincrement())
  role_name String @unique @db.VarChar(50)
  users     User[]

  @@map("roles")
}

model User {
  user_id            Int       @id @default(autoincrement())
  full_name          String    @db.VarChar(255)
  email              String    @unique @db.VarChar(320)
  password_hash      String    @db.VarChar(255)
  role_id            Int
  account_status     String    @default("active") @db.VarChar(20)
  last_login         DateTime?
  failed_login_count Int       @default(0)
  lockout_until      DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  role               Role      @relation(fields: [role_id], references: [role_id])
  login_logs         LoginLog[]
  student            Student?
  supervisor         Supervisor?
  university_users   UniversityUser[]
  sent_messages      Message[]  @relation("SentMessages")
  received_messages  Message[]  @relation("ReceivedMessages")
  notifications      Notification[]
  uploaded_docs      Document[]
  uploaded_templates Template[]
  activity_logs      ActivityLog[]
  status_changes     StatusHistory[] @relation("StatusChanger")
  published_evaluations Evaluation[]
  reviewed_reports   MonthlyReport[] @relation("MonthlyReportReviewer")
  approved_universities University[]

  @@map("users")
}

model LoginLog {
  log_id     Int      @id @default(autoincrement())
  user_id    Int
  login_time DateTime @default(now())
  ip_address String   @db.VarChar(45)
  status     String   @db.VarChar(20)

  user       User     @relation(fields: [user_id], references: [user_id])

  @@index([user_id, login_time])
  @@map("login_logs")
}

// ─── ORGANIZATION ─────────────────────────────────────────────────────────
model University {
  university_id   Int               @id @default(autoincrement())
  name            String            @db.VarChar(255)
  contact_email   String            @db.VarChar(320)
  address         String            @db.Text
  approval_status String            @default("pending") @db.VarChar(20)
  rejected_reason String?           @db.Text
  approved_by     Int?
  approved_at     DateTime?
  created_at      DateTime          @default(now())
  created_by      Int

  university_users UniversityUser[]
  students        Student[]
  applications    Application[]
  bulk_applications BulkApplication[]
  approver        User?             @relation(fields: [approved_by], references: [user_id])

  @@index([approval_status])
  @@map("universities")
}

model UniversityUser {
  university_user_id Int        @id @default(autoincrement())
  user_id            Int
  university_id      Int
  role_title         String?    @db.VarChar(100)

  user               User       @relation(fields: [user_id], references: [user_id])
  university         University @relation(fields: [university_id], references: [university_id])

  @@unique([user_id, university_id])
  @@map("university_users")
}

// ─── STUDENTS ─────────────────────────────────────────────────────────────
model Student {
  student_id          Int                  @id @default(autoincrement())
  user_id             Int?                 @unique
  university_id       Int
  full_name           String               @db.VarChar(255)
  registration_number String               @db.VarChar(100)
  email               String               @db.VarChar(320)
  department          String               @db.VarChar(150)
  gpa                 Float?
  status              String               @default("pending") @db.VarChar(30)
  created_at          DateTime             @default(now())

  user                User?                @relation(fields: [user_id], references: [user_id])
  university          University           @relation(fields: [university_id], references: [university_id])
  application_students ApplicationStudent[]
  internships         Internship[]
  submissions         Submission[]
  attendance          Attendance[]
  monthly_reports     MonthlyReport[]
  evaluations         Evaluation[]
  group_memberships   StudentGroupMember[]
  led_groups          StudentGroup[]        @relation("StudentGroupLeader")

  @@index([university_id])
  @@map("students")
}

// ─── APPLICATIONS ─────────────────────────────────────────────────────────
model Application {
  application_id       Int                  @id @default(autoincrement())
  university_id        Int
  submitted_by         Int
  application_type     String               @default("bulk") @db.VarChar(20)
  application_letter_path String?           @db.VarChar(500)
  submission_date      DateTime             @default(now())
  status               String               @default("pending") @db.VarChar(30)
  reviewed_by          Int?
  reviewed_at          DateTime?
  remarks              String?              @db.Text

  university           University           @relation(fields: [university_id], references: [university_id])
  application_students ApplicationStudent[]
  internships          Internship[]
  bulk_applications    BulkApplication[]

  @@index([university_id, status])
  @@index([status, submission_date])
  @@map("applications")
}

model BulkApplication {
  bulk_application_id Int          @id @default(autoincrement())
  application_id      Int
  university_id       Int
  file_name           String       @db.VarChar(255)
  file_path           String       @db.VarChar(500)
  total_records       Int
  processed_records   Int          @default(0)
  failed_records      Int          @default(0)
  submission_date     DateTime     @default(now())
  status              String       @default("pending") @db.VarChar(30)
  error_log           String?      @db.Text

  application         Application  @relation(fields: [application_id], references: [application_id])
  university          University   @relation(fields: [university_id], references: [university_id])

  @@index([university_id, status])
  @@map("bulk_applications")
}

model ApplicationStudent {
  id             Int         @id @default(autoincrement())
  application_id Int
  student_id     Int
  status         String      @default("pending") @db.VarChar(30)
  remarks        String?     @db.Text

  application    Application @relation(fields: [application_id], references: [application_id])
  student        Student     @relation(fields: [student_id], references: [student_id])

  @@unique([application_id, student_id])
  @@index([application_id, status])
  @@map("application_students")
}

// ─── INTERNSHIPS ──────────────────────────────────────────────────────────
model Internship {
  internship_id   Int            @id @default(autoincrement())
  student_id      Int
  application_id  Int
  assignment_id   Int?
  start_date      DateTime?      @db.Date
  end_date        DateTime?      @db.Date
  status          String         @default("pending_assignment") @db.VarChar(30)
  created_at      DateTime       @default(now())

  student         Student        @relation(fields: [student_id], references: [student_id])
  application     Application    @relation(fields: [application_id], references: [application_id])
  assignment      Assignment?
  milestones      Milestone[]
  attendance      Attendance?
  monthly_reports MonthlyReport[]
  evaluation      Evaluation?

  // Partial unique index enforced via migration SQL:
  // CREATE UNIQUE INDEX uq_student_active_internship
  //   ON internships(student_id) WHERE status = 'active';
  @@index([student_id, status])
  @@map("internships")
}

// ─── SUPERVISION ──────────────────────────────────────────────────────────
model Supervisor {
  supervisor_id Int          @id @default(autoincrement())
  user_id       Int          @unique
  department    String       @db.VarChar(150)
  position      String       @db.VarChar(150)
  max_students  Int          @default(10)
  created_at    DateTime     @default(now())

  user          User         @relation(fields: [user_id], references: [user_id])
  assignments   Assignment[]
  evaluations   Evaluation[]
  student_groups StudentGroup[]

  @@map("supervisors")
}

model Assignment {
  assignment_id Int        @id @default(autoincrement())
  internship_id Int        @unique
  supervisor_id Int
  assigned_by   Int
  start_date    DateTime?  @db.Date
  end_date      DateTime?  @db.Date
  status        String     @default("active") @db.VarChar(30)
  created_at    DateTime   @default(now())

  internship    Internship @relation(fields: [internship_id], references: [internship_id])
  supervisor    Supervisor @relation(fields: [supervisor_id], references: [supervisor_id])

  @@index([supervisor_id, status])
  @@map("assignments")
}

model StudentGroup {
  group_id           Int                  @id @default(autoincrement())
  supervisor_id      Int
  team_name          String?              @db.VarChar(150)
  leader_student_id  Int?
  start_date         DateTime?            @db.Date
  end_date           DateTime?            @db.Date
  attendance_days    String?              @db.VarChar(100) // e.g. "monday,wednesday,friday"
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt

  supervisor         Supervisor           @relation(fields: [supervisor_id], references: [supervisor_id])
  leader             Student?             @relation("StudentGroupLeader", fields: [leader_student_id], references: [student_id])
  members            StudentGroupMember[]

  @@index([supervisor_id])
  @@map("student_groups")
}

model StudentGroupMember {
  group_member_id    Int          @id @default(autoincrement())
  group_id           Int
  student_id         Int
  is_leader          Boolean      @default(false)
  created_at         DateTime     @default(now())

  group              StudentGroup @relation(fields: [group_id], references: [group_id], onDelete: Cascade)
  student            Student      @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@unique([group_id, student_id])
  @@index([student_id])
  @@map("student_group_members")
}

// ─── EXECUTION LAYER ──────────────────────────────────────────────────────
model Milestone {
  milestone_id Int          @id @default(autoincrement())
  internship_id Int
  title        String       @db.VarChar(255)
  description  String?      @db.Text
  due_date     DateTime?    @db.Date
  status       String       @default("open") @db.VarChar(30)
  created_by   Int
  created_at   DateTime     @default(now())

  internship   Internship   @relation(fields: [internship_id], references: [internship_id])
  submissions  Submission[]

  @@index([internship_id, status])
  @@map("milestones")
}

model Submission {
  submission_id Int               @id @default(autoincrement())
  milestone_id  Int
  student_id    Int
  content       String            @db.Text
  submitted_at  DateTime          @default(now())
  status        String            @default("submitted") @db.VarChar(30)

  milestone     Milestone         @relation(fields: [milestone_id], references: [milestone_id])
  student       Student           @relation(fields: [student_id], references: [student_id])
  review        SubmissionReview?

  @@index([milestone_id, submitted_at])
  @@map("submissions")
}

model SubmissionReview {
  review_id     Int        @id @default(autoincrement())
  submission_id Int        @unique
  reviewer_id   Int
  feedback      String?    @db.Text
  status        String     @db.VarChar(30)
  reviewed_at   DateTime   @default(now())

  submission    Submission @relation(fields: [submission_id], references: [submission_id])

  @@map("submission_reviews")
}

// ─── ATTENDANCE & REPORTING ───────────────────────────────────────────────
model Attendance {
  attendance_id Int        @id @default(autoincrement())
  internship_id Int        @unique
  student_id    Int
  month         Int
  year          Int
  percentage    Float
  attendance_sheet Json?
  total_absent_days Int    @default(0)
  marked_by     Int
  updated_at    DateTime   @updatedAt

  internship        Internship          @relation(fields: [internship_id], references: [internship_id])
  student           Student             @relation(fields: [student_id], references: [student_id])
  attendance_details AttendanceDetail[]

  // CHECK: percentage >= 0 AND percentage <= 100 — enforced via migration
  @@unique([internship_id, month, year])
  @@map("attendance")
}

model AttendanceDetail {
  attendance_detail_id Int     @id @default(autoincrement())
  attendance_id        Int
  week                 Int
  week_start_date      DateTime? @db.Date
  week_end_date        DateTime? @db.Date
  monday               Boolean?
  tuesday              Boolean?
  wednesday            Boolean?
  thursday             Boolean?
  friday               Boolean?

  attendance           Attendance @relation(fields: [attendance_id], references: [attendance_id], onDelete: Cascade)

  @@index([attendance_id, week])
  @@map("attendance_details")
}

model MonthlyReport {
  report_id     Int        @id @default(autoincrement())
  internship_id Int
  student_id    Int
  month         Int
  year          Int
  summary       String     @db.Text
  submitted_at  DateTime   @default(now())
  reviewed_by   Int?
  feedback      String?    @db.Text
  status        String     @default("submitted") @db.VarChar(30)

  internship    Internship @relation(fields: [internship_id], references: [internship_id])
  student       Student    @relation(fields: [student_id], references: [student_id])
  reviewer      User?      @relation("MonthlyReportReviewer", fields: [reviewed_by], references: [user_id])

  @@unique([internship_id, month, year])
  @@index([internship_id, year, month])
  @@map("monthly_reports")
}

// ─── EVALUATION ───────────────────────────────────────────────────────────
model Evaluation {
  evaluation_id Int        @id @default(autoincrement())
  internship_id Int        @unique
  student_id    Int
  supervisor_id Int
  
  // General Performance Metrics (25%)
  punctuality_score         Float?
  reliability_score         Float?
  independence_score        Float?
  communication_score       Float?
  professionalism_score     Float?
  general_performance_total Float?
  
  // Personal Skills Metrics (25%)
  speed_of_work_score       Float?
  accuracy_score            Float?
  engagement_score          Float?
  need_for_work_score       Float?
  cooperation_score         Float?
  personal_skills_total     Float?
  
  // Professional Skills Metrics (50%)
  technical_skills_score    Float?
  organizational_skills_score Float?
  project_support_score     Float?
  responsibility_score      Float?
  team_quality_score        Float?
  professional_skills_total Float?
  
  // Attendance
  attendance_percentage     Float?
  total_absent_days         Int?
  
  // Overall
  total_score       Int
  grade             String     @db.VarChar(2)
  remarks           String     @db.Text
  
  submitted_at  DateTime   @default(now())
  published_at  DateTime?
  published_by  Int?
  status        String     @default("draft") @db.VarChar(20)

  internship    Internship @relation(fields: [internship_id], references: [internship_id])
  student       Student    @relation(fields: [student_id], references: [student_id])
  supervisor    Supervisor @relation(fields: [supervisor_id], references: [supervisor_id])
  admin_user    User?      @relation(fields: [published_by], references: [user_id])

  // CHECK total_score >= 0 AND total_score <= 100 enforced via migration
  @@map("evaluations")
}

// ─── COMMUNICATION ────────────────────────────────────────────────────────
model Message {
  message_id   Int      @id @default(autoincrement())
  sender_id    Int
  receiver_id  Int
  message_text String   @db.Text
  sent_at      DateTime @default(now())
  read_status  String   @default("unread") @db.VarChar(10)

  sender       User     @relation("SentMessages",    fields: [sender_id],   references: [user_id])
  receiver     User     @relation("ReceivedMessages", fields: [receiver_id], references: [user_id])

  @@index([sender_id, receiver_id, sent_at])
  @@index([receiver_id, read_status])
  @@map("messages")
}

model Notification {
  notification_id Int      @id @default(autoincrement())
  user_id         Int
  title           String   @db.VarChar(255)
  message         String   @db.Text
  type            String   @db.VarChar(50)
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())

  user            User     @relation(fields: [user_id], references: [user_id])

  @@index([user_id, is_read])
  @@map("notifications")
}

// ─── TEMPLATES ────────────────────────────────────────────────────────────
model Template {
  template_id   Int      @id @default(autoincrement())
  template_name String   @db.VarChar(255)
  file_name     String   @db.VarChar(255)
  file_path     String   @db.VarChar(500)
  file_type     String   @db.VarChar(100)
  uploaded_by   Int
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  uploader      User     @relation(fields: [uploaded_by], references: [user_id])

  @@index([is_active])
  @@map("templates")
}

// ─── DOCUMENTS ────────────────────────────────────────────────────────────
model DocumentType {
  type_id   Int        @id @default(autoincrement())
  type_name String     @unique @db.VarChar(100)
  documents Document[]

  @@map("document_types")
}

model Document {
  document_id      Int          @id @default(autoincrement())
  file_name        String       @db.VarChar(255)
  file_path        String       @db.VarChar(500)
  file_type        String       @db.VarChar(255)
  document_type_id Int
  uploaded_by      Int
  entity_type      String       @db.VarChar(50)
  entity_id        Int
  uploaded_at      DateTime     @default(now())

  document_type    DocumentType @relation(fields: [document_type_id], references: [type_id])
  uploader         User         @relation(fields: [uploaded_by], references: [user_id])

  @@index([entity_type, entity_id])
  @@map("documents")
}

// ─── AUDIT ────────────────────────────────────────────────────────────────
model StatusHistory {
  history_id  Int      @id @default(autoincrement())
  entity_type String   @db.VarChar(50)
  entity_id   Int
  old_status  String?  @db.VarChar(30)
  new_status  String   @db.VarChar(30)
  changed_by  Int
  changed_at  DateTime @default(now())
  comment     String?  @db.Text

  changer     User     @relation("StatusChanger", fields: [changed_by], references: [user_id])

  @@index([entity_type, entity_id])
  @@index([changed_by, changed_at])
  @@map("status_history")
}

model ActivityLog {
  log_id      Int      @id @default(autoincrement())
  user_id     Int
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(50)
  entity_id   Int?
  ip_address  String?  @db.VarChar(45)
  timestamp   DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [user_id])

  @@index([user_id, timestamp])
  @@index([entity_type, entity_id])
  @@map("activity_logs")
}
